rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Saved fraud analyses. Any signed-in user (incl. anonymous session used
    // by the default Admin login) may read/write. Tighten to `request.auth.token`
    // checks if you add per-user ownership later.
    match /fraud_datasets/{docId} {
      allow read, write: if request.auth != null;

      // Chunked payload storage for analyses that exceed Firestore's
      // 1 MiB single-document limit.
      match /chunks/{chunkId} {
        allow read, write: if request.auth != null;
      }
    }
    // Publisher <-> PID mappings (keyed per app to allow re-brokering).
    match /publisher_map/{docId} {
      allow read, write: if request.auth != null;
    }
    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
